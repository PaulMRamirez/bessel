{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@bessel/spice": ["./packages/spice/src/index.ts"],
      "@bessel/catalog": ["./packages/catalog/src/index.ts"],
      "@bessel/scene": ["./packages/scene/src/index.ts"],
      "@bessel/timeline": ["./packages/timeline/src/index.ts"],
      "@bessel/state": ["./packages/state/src/index.ts"],
      "@bessel/color": ["./packages/color/src/index.ts"],
      "@bessel/pal": ["./packages/pal/src/index.ts"],
      "@bessel/pal-web": ["./packages/pal-web/src/index.ts"],
      "@bessel/pal-capacitor": ["./packages/pal-capacitor/src/index.ts"],
      "@bessel/pal-electron": ["./packages/pal-electron/src/index.ts"],
      "@bessel/ui": ["./packages/ui/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src",
    "apps/*/src",
    "apps/*/electron",
    "apps/web/vite.config.ts",
    "e2e"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/out",
    "vendor",
    "packages/spice/wasm"
  ]
}
